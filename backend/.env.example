SPRING_DATASOURCE_URL=jdbc:mysql://[HOST]:[PORT]/[DATABASE]
SPRING_DATASOURCE_USERNAME=[PLACEHOLDER_USER]
SPRING_DATASOURCE_PASSWORD=[PLACEHOLDER_PASSWORD]
JWT_SECRET=[PLACEHOLDER_JWT_SECRET_MIN_64_CHARS]
CORS_ALLOWED_ORIGIN=[ALLOWED_ORIGIN]
SPRING_MAIL_HOST=[SMTP_HOST]
SPRING_MAIL_PORT=[SMTP_PORT]
SPRING_MAIL_USERNAME=[SMTP_USER]
SPRING_MAIL_PASSWORD=[SMTP_PASSWORD]
APP_URL=[APP_URL]
STOCK_ALERT_COOLDOWN=[COOLDOWN_HOURS]
